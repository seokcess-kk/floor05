# floor05 환경변수 설정
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요

# 사이트 URL (Vercel 배포 후 설정)
NEXT_PUBLIC_SITE_URL=https://floor05.com

# Google AdSense
# https://www.google.com/adsense 에서 발급
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX

# Kakao Adfit (AdSense 대신 사용 가능)
# https://adfit.kakao.com 에서 발급
NEXT_PUBLIC_ADFIT_UNIT_ID=

# Google Search Console 인증
# https://search.google.com/search-console 에서 발급
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics (선택사항, Vercel Analytics 사용 시 불필요)
NEXT_PUBLIC_GA_ID=

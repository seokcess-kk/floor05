# floor05 환경변수 설정
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요

# 사이트 URL (Vercel 배포 후 설정)
# canonical/OG/sitemap이 모두 이 값으로 통일됨 — 반드시 www 호스트로 유지
NEXT_PUBLIC_SITE_URL=https://www.floor05.com

# Google AdSense
# https://www.google.com/adsense 에서 발급
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX
# AdSense > 광고 > 광고 단위에서 "반응형 디스플레이" 단위 생성 후 숫자 슬롯 ID 입력
# (미설정 시 AdSense 광고는 표시되지 않음 — 잘못된 광고 요청 방지)
NEXT_PUBLIC_ADSENSE_SLOT_ID=

# Kakao Adfit (AdSense 슬롯 미설정 시 대체 노출)
# https://adfit.kakao.com 에서 발급 (예: DAN-xxxxxxxx)
NEXT_PUBLIC_ADFIT_UNIT_ID=

# Google Search Console 인증
# https://search.google.com/search-console 에서 발급
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics (선택사항, Vercel Analytics 사용 시 불필요)
NEXT_PUBLIC_GA_ID=
